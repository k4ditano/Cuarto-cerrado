# --- Ollama Cloud ---
# Saca tu clave en https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Modelo. Algunos cloud disponibles:
#   gpt-oss:120b-cloud   (recomendado)
#   gpt-oss:20b-cloud    (más rápido)
#   deepseek-v3.1:671b-cloud
#   qwen3-coder:480b-cloud
# Si tienes Ollama local, puedes apuntar a tu propia URL abajo y usar gemma3:27b u otros.
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_BASE_URL=https://ollama.com

# Modelo con visión (para ver imágenes y describir lo que hay). Algunos:
#   qwen2.5vl:32b        (local, requiere VRAM)
#   gemma3:27b           (local, multimodal)
#   llava:13b            (local, más ligero)
# Si tu setup no tiene modelo con visión, los hotspots seguirán funcionando pero
# las preguntas libres sobre la imagen no.
OLLAMA_VISION_MODEL=qwen2.5vl:32b

# --- OpenAI Images ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
# low = barato (~$0.006/img), medium, high
OPENAI_IMAGE_QUALITY=low

# --- Servidor ---
PORT=3000

# Si quieres protegerlo con un PIN simple (opcional, déjalo vacío para abrir)
ACCESS_PIN=
